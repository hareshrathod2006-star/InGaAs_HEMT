(sde:clear)
;-------------------------------------------------------------------------------------
; InGaAs HEMT  -  SDE structure file
; Substrate variant : Si-DOPED lower 0.5 um GaAs
;
; Workbench parameters used in this file
;   @Si_Conc@  - Silicon donor doping in lower 0.5 um GaAs substrate
;                [cm^-3]  Typical range : 1e15 to 1e18
;                Silicon in GaAs occupies the Ga site (Si_Ga) and acts
;                as a shallow donor (ED ~ EC - 0.006 eV).
;                (Trap concentrations @Si_Trap1_Conc@ and @Si_Trap2_Conc@
;                 are physics quantities defined only in the paired
;                 SDevice file and do NOT affect geometry or meshing.)
;----------------------------------------------------------------------;
; Definitions
;----------------------------------------------------------------------;
(define  HGaAsSub   0.8)
(display "Height of GaAs substrate: ") (display HGaAsSub) (display "um") (newline)

(define  HGaAsUpper 0.3)   ; upper buffer  - unchanged, background doping only
(define  HGaAsLower 0.5)   ; lower region  - Si donor doped via @Si_Conc@

(define  HChannel   0.01)
(display "Height of channel: ") (display HChannel) (display "um") (newline)

(define  HSpacer    0.0345)
(display "Height of spacer: ") (display HSpacer) (display "um") (newline)

(define  YDelta     0.031)
(display "Location of Delta-Doping layer: ") (display YDelta) (display "um") (newline)

(define  DeltaThick 0.002)
(display "Thickness of Delta-Doping layer: ") (display DeltaThick) (display "um") (newline)

(define  HGaAsCap   0.03)
(display "Height of GaAs cap: ") (display HGaAsCap) (display "um") (newline)

(define  HPass      0.05)
(display "Height of passivation: ") (display HPass) (display "um") (newline)

(define  Xmax    0.8)
(define  Lg      0.25)
(define  Lc      0.05)
(define  GRecess 0.015)
(define  Wsp     0.04)
(define  WTrap   0.03)
(define  SheetCharge 5.4e12)
(display "SheetCharge: ") (display SheetCharge) (display "cm-2") (newline)

;--- Silicon doping concentration from Workbench ----------------------
; Si_Ga in GaAs is a shallow donor. At concentrations above ~1e18 cm^-3
; amphoteric behaviour (Si_As acceptor) can appear, but in the 1e15-1e17
; range used for buffer engineering it is purely n-type.
(define Si_Conc @Si_Conc@)
(display "Si doping lower substrate: ") (display Si_Conc) (display "cm-3") (newline)

;----------------------------------------------------------------------;
; Derived Quantities
;----------------------------------------------------------------------;
(define Y0   0.0)
(define Y1   (+ Y0  HSpacer))
(define Y2   (+ Y1  HChannel))
(define Y2u  (+ Y2  HGaAsUpper))   ; boundary between upper and lower substrate
(define Y3   (+ Y2  HGaAsSub))     ; bottom of full substrate
(define Ym1  (- Y0  HGaAsCap))
(define Ym2  (- Ym1 HPass))

(define Xg   (/ Lg 2.0))
(define Xsp  (+ Xg Wsp))
(define Xgt  (+ Xg WTrap))
(define Xc   (- Xmax Lc))
(define XcM  (-  Xmax (* 2.5 Lc)))
(define Yg   (+ Y0 GRecess))
(define XT   0.3)

;----------------------------------------------------------------------;
; Layer System
;----------------------------------------------------------------------;

; Upper buffer 0.3 um - background doping only, unchanged from original
(sdegeo:create-rectangle
 (position Y2  0.0  0)
 (position Y2u Xmax 0) "GaAs" "R.GaAsUpper")

; Lower substrate 0.5 um - Silicon donor doped at @Si_Conc@
; Region name R.GaAsLower is referenced in paired SDevice Traps{} block.
(sdegeo:create-rectangle
 (position Y2u 0.0  0)
 (position Y3  Xmax 0) "GaAs" "R.GaAsLower")

(sdegeo:create-rectangle
 (position Y1 0.0  0)
 (position Y2 Xmax 0) "InGaAs" "R.Channel")

(sdegeo:create-rectangle
 (position Y0 0.0  0)
 (position Y1 Xmax 0) "AlGaAs" "R.SpacerB")

(sdegeo:create-rectangle
 (position Ym1 0.0  0)
 (position Y0  Xmax 0) "GaAs" "R.GaAsCap")

(sdegeo:create-rectangle
 (position Ym2 0.0  0)
 (position Ym1 Xmax 0) "Si3N4" "R.Passivation")

(sdegeo:set-default-boolean "ABA")
(sdegeo:create-rectangle
  (position Ym2 0.0 0)
  (position Yg  Xsp 0) "Oxide" "R.Oxide")

(define GateMetal
 (sdegeo:create-rectangle
  (position Ym2 0.0 0)
  (position Yg  Xg  0) "Metal" "R.GateMetal"))

(define DrainMetal
 (sdegeo:create-rectangle
  (position  Ym2 Xc   0)
  (position  Y2  Xmax 0) "Metal" "R.DrainMetal"))

;--- Contacts ---------------------------------------------------------
(sdegeo:define-contact-set "gate"      4.0 (color:rgb 1.0 0.0 0.0) "##")
(sdegeo:define-contact-set "drain"     4.0 (color:rgb 0.0 1.0 0.0) "##")
(sdegeo:define-contact-set "substrate" 4.0 (color:rgb 0.5 0.0 0.5) "##")

(sdegeo:set-current-contact-set "gate")
(sdegeo:set-contact-boundary-edges GateMetal)
(sdegeo:delete-region GateMetal)

(sdegeo:set-current-contact-set "drain")
(sdegeo:set-contact-boundary-edges DrainMetal)
(sdegeo:delete-region DrainMetal)

(sdegeo:define-2d-contact
 (find-edge-id (position Y3 0.01 0.0))
 "substrate")

(sdeio:save-tdr-bnd (get-body-list) "n@node@_half_bnd.tdr")

;----------------------------------------------------------------------;
; Doping Profiles
;----------------------------------------------------------------------;

; Background intrinsic level for all materials
(sdedr:define-constant-profile "Const.BG"
 "BoronActiveConcentration" 1e7)
(sdedr:define-constant-profile-material "PlaceCD.BG"  "Const.BG" "GaAs")
(sdedr:define-constant-profile-material "PlaceCD.BG2" "Const.BG" "AlGaAs")
(sdedr:define-constant-profile-material "PlaceCD.BG3" "Const.BG" "InGaAs")

; Silicon donor doping in lower 0.5 um substrate
; ArsenicActiveConcentration is used as the n-type donor proxy in Sentaurus
; for GaAs Si_Ga doping when no dedicated Si species model is active.
; If your parameter file has a Si model enabled, replace with
; PhosphorusActiveConcentration or the appropriate Si donor species.
(sdedr:define-constant-profile "Const.SiDope"
 "ArsenicActiveConcentration" Si_Conc)
(sdedr:define-constant-profile-region "PlaceCD.SiLower"
 "Const.SiDope" "R.GaAsLower")

; Delta-doping in AlGaAs spacer
(sdedr:define-refeval-window "BaseLine.Delta" "Line"
 (position YDelta (* Xmax -1.0) 0.0)
 (position YDelta (* Xmax  2.0) 0.0))
(sdedr:define-gaussian-profile "Prof.Delta"
 "ArsenicActiveConcentration"
 "PeakPos" 0  "PeakVal" (* (/ SheetCharge DeltaThick) 1.12838e4)
 "Length" (* 0.5 DeltaThick)
 "Gauss"  "Factor" 0.0)
(sdedr:define-analytical-profile-placement "Place.Delta"
 "Prof.Delta" "BaseLine.Delta" "Both" "NoReplace" "Eval")

; GaAs cap n+
(sdedr:define-constant-profile "Const.GaAsCap"
 "ArsenicActiveConcentration" 3e18)
(sdedr:define-constant-profile-region "PlaceCD.GaAsCap"
 "Const.GaAsCap" "R.GaAsCap")

; Source/Drain implants
(sdedr:define-refeval-window "BaseLine.SD" "Line"
 (position Ym1 (-  Xmax (* 2 Lc)) 0.0)
 (position Ym1 (* 2 Xmax)         0.0))
(sdedr:define-gaussian-profile "Impl.SDprof"
 "ArsenicActiveConcentration"
 "PeakPos" 0  "PeakVal" 1e19
 "ValueAtDepth" 5e17 "Depth" (* 1.75 (- Y2 Ym1))
 "Gauss"  "Factor" 0.4)
(sdedr:define-analytical-profile-placement "Impl.Ext"
 "Impl.SDprof" "BaseLine.SD" "Negative" "NoReplace" "Eval")

;----------------------------------------------------------------------;
; Meshing
;----------------------------------------------------------------------;
(sdedr:define-refinement-size "Ref.GaAsSub"
  (/ Y3  8.0) (/ Xmax 4.0)
  (/ Y3 16.0) (/ Xmax 8.0))
(sdedr:define-refinement-region "RefPlace.GaAsUpper"
 "Ref.GaAsSub" "R.GaAsUpper")
(sdedr:define-refinement-region "RefPlace.GaAsLower"
 "Ref.GaAsSub" "R.GaAsLower")

(sdedr:define-refeval-window "RWin.Cap" "Rectangle"
 (position  (- Ym1 0.01)  0.0  0.0)
 (position  Y0    XcM     0.0))
(sdedr:define-refinement-size "Ref.Cap"
  (/ HGaAsCap 4.0) (/ Xmax  8.0)
  (/ HGaAsCap 6.0) (/ Xmax 16.0))
(sdedr:define-refinement-placement "RefPlace.Cap" "Ref.Cap" "RWin.Cap")

(sdedr:define-refeval-window "RWin.Spacer" "Rectangle"
 (position  Y0 0.0 0.0)
 (position  Y1 XT  0.0))
(sdedr:define-refinement-size "Ref.Spacer"
  (/ HSpacer 6.0) 99
  (/ HSpacer 8.0) 66)
(sdedr:define-refinement-placement "RefPlace.Spacer" "Ref.Spacer" "RWin.Spacer")

(sdedr:define-refeval-window "MBWindow.ChannelTop" "Rectangle"
 (position (- Y1 8e-4)        XT    0.0)
 (position (* 0.5 (+ Y2 Y1))  XcM   0.0))
(sdedr:define-multibox-size "MBSize.ChannelTop"
  0.1 99  8e-4 66  1.5 1.0)
(sdedr:define-multibox-placement "MBPlace.ChannelTop"
 "MBSize.ChannelTop" "MBWindow.ChannelTop")

(sdedr:define-refeval-window "MBWindow.ChannelTopT" "Rectangle"
 (position (- Y1 4e-4)       0.0  0.0)
 (position (* 0.5 (+ Y2 Y1)) XT   0.0))
(sdedr:define-multibox-size "MBSize.ChannelTopT"
  0.05 99  4e-4 66  1.5 1.0)
(sdedr:define-multibox-placement "MBPlace.ChannelTopT"
 "MBSize.ChannelTopT" "MBWindow.ChannelTopT")

(sdedr:define-refeval-window "MBWindow.ChannelBot" "Rectangle"
 (position (* 0.5 (+ Y2 Y1))  XT    0.0)
 (position (+ Y2 8e-4)        XcM   0.0))
(sdedr:define-multibox-size "MBSize.ChannelBot"
  0.1 99  8e-4 66  -1.5 1.0)
(sdedr:define-multibox-placement "MBPlace.ChannelBot"
 "MBSize.ChannelBot" "MBWindow.ChannelBot")

(sdedr:define-refeval-window "MBWindow.ChannelBotT" "Rectangle"
 (position (* 0.5 (+ Y2 Y1)) 0.0  0.0)
 (position  (+ Y2 4e-4)      XT   0.0))
(sdedr:define-multibox-size "MBSize.ChannelBotT"
  0.05 99  4e-4 66  -1.5 1.0)
(sdedr:define-multibox-placement "MBPlace.ChannelBotT"
 "MBSize.ChannelBotT" "MBWindow.ChannelBotT")

(sdedr:define-refeval-window "MBWindow.UnderChannel" "Rectangle"
 (position Y2  0.0  0.0)
 (position Y3  XcM  0.0))
(sdedr:define-multibox-size "MBSize.UnderChannel"
  66 99  16e-4 66  2.0 1.0)
(sdedr:define-multibox-placement "MBPlace.UnderChannel"
 "MBSize.UnderChannel" "MBWindow.UnderChannel")

; Fine mesh at the Si-doping boundary Y2u
(sdedr:define-refeval-window "RWin.SiSplit" "Rectangle"
 (position (- Y2u 0.02) 0.0   0.0)
 (position (+ Y2u 0.02) Xmax  0.0))
(sdedr:define-refinement-size "Ref.SiSplit"
  5e-3 (/ Xmax 4.0)
  2e-3 (/ Xmax 8.0))
(sdedr:define-refinement-placement "RefPlace.SiSplit"
 "Ref.SiSplit" "RWin.SiSplit")

(sdedr:define-refeval-window "RWin.HeteroCap" "Rectangle"
 (position  (- Y0 3e-4) Xsp  0.0)
 (position  (+ Y0 3e-4) XcM  0.0))
(sdedr:define-refinement-size "Ref.HeteroCap"
  6e-4 99  8e-4 66)
(sdedr:define-refinement-placement "RefPlace.HeteroCap"
 "Ref.HeteroCap" "RWin.HeteroCap")

(sdedr:define-refeval-window "RWin.ActiveArea" "Rectangle"
 (position  (- Y0 0.01) 0.0 0.0)
 (position  (+ Y2 0.05) (+  0.5 Xsp) 0.0))
(sdedr:define-refinement-size "Ref.ActiveArea"
  0.025 (/ Lg 4.0)
   0.02 (/ Lg 5.0))
(sdedr:define-refinement-placement "RefPlace.ActiveArea"
