   (+ YDelta (* 1.00 DeltaThick))
   (+ YDelta (* 0.75 DeltaThick))
   (+ YDelta (* 0.50 DeltaThick))
   (+ YDelta (* 0.25 DeltaThick))
   (+ YDelta (* 0.125 DeltaThick))
      YDelta
   (- YDelta (* 0.125 DeltaThick))
   (- YDelta (* 0.25 DeltaThick))
   (- YDelta (* 0.50 DeltaThick))
   (- YDelta (* 0.75 DeltaThick))
   (- YDelta (* 1.00 DeltaThick))
   (- YDelta (* 1.25 DeltaThick))
   (- YDelta (* 1.50 DeltaThick))
   (- YDelta (* 2.00 DeltaThick))
   Y2u    ; explicit cut at the upper/lower substrate boundary
  )
)





*----------------------------------------------------------------------*
* SDevice input  -  InGaAs HEMT with Si-DOPED lower GaAs substrate
*
* ======================================================================
* Workbench parameters used in this file
* ======================================================================
*
*  @Si_Conc@           - Silicon donor doping in R.GaAsLower [cm^-3]
*                        Range: 1e15 to 1e18
*                        Must match the value used in the paired SDE node.
*                        Si_Ga in GaAs is a shallow donor (EC - 0.006 eV).
*
*  @Si_Trap1_Conc@     - Concentration of Trap 1 in R.GaAsLower
*                        DX-centre / Si-related deep donor at EC - 0.15 eV
*                        [cm^-3]  Suggested range: 1e14 to 0.1 * @Si_Conc@
*                        Ref: Mooney, J.Appl.Phys. 67, R1 (1990)
*                             Chadi & Chang, Phys.Rev.Lett. 61,873 (1988)
*
*  @Si_Trap2_Conc@     - Concentration of Trap 2 in R.GaAsLower
*                        Si-related mid-gap compensating acceptor at
*                        EV + 0.45 eV (Si_As antisite in high-Si material)
*                        [cm^-3]  Suggested range: 1e13 to 0.05 * @Si_Conc@
*                        Ref: Look et al., Phys.Rev.B 42, 3578 (1990)
*
*  @Si_UpperTrap_Conc@ - Concentration of original substrate trap
*                        in R.GaAsUpper (donor at 0.61 eV from CB)
*                        [cm^-3]  Baseline from original code: 1e16
*
* Physical background (Si-doped GaAs):
*   Silicon on the Ga site (Si_Ga) is a shallow donor in GaAs.
*   At low-to-moderate concentrations (< ~2e17 cm^-3) it behaves as
*   a simple n-type dopant. Two important trap states are introduced:
*
*   Trap 1 - DX centre (Si_Ga deep donor)
*     Under pressure or in AlGaAs alloys the Si_Ga level can transform
*     into a large-lattice-relaxation DX state. In GaAs at atmospheric
*     pressure this is metastable, but a residual density of DX-like
*     trapping states exists and is relevant for buffer engineering.
*     Energy:    EC - 0.15 eV  (below conduction band)
*     Type:      Donor (neutral when empty, negative when doubly occupied)
*     Modelled as Acceptor in Sentaurus because DX captures electrons
*     and becomes negative (acts as electron trap from CB perspective).
*     eXsection: 1.0e-14 cm^2  (large - DX has strong lattice coupling)
*     hXsection: 1.0e-19 cm^2  (very small - deep, minimal hole coupling)
*     Ref: Mooney, J.Appl.Phys. 67, R1 (1990)
*
*   Trap 2 - Si_As antisite / compensating acceptor
*     At higher Si concentrations or under As-rich growth, a fraction
*     of Si atoms sit on As sites, acting as acceptors and partially
*     compensating the donors. This level sits near mid-gap.
*     Energy:    EV + 0.45 eV  =>  1.42 - 0.45 = 0.97 eV fromCondBand
*     Type:      Acceptor
*     eXsection: 2.0e-16 cm^2
*     hXsection: 1.0e-15 cm^2
*     Ref: Look et al., Phys.Rev.B 42, 3578 (1990)
* ======================================================================
*----------------------------------------------------------------------*
Device HEMT {
*----------------------------------------------------------------------*
Electrode{
   { Name="source"    Voltage= 0.0 Resistor= 150 }
   { Name="drain"     Voltage= 0.0 Resistor= 150 }
   { Name="gate"      Voltage= 0.0 Schottky Barrier= 0.9
       eRecVelocity= 1.e7 hRecVelocity= 1.e7 }
   { Name="substrate" Voltage= 0.0 Resistor= 1e3 }
}
File{
   Grid=      "@tdr@"
   Parameter= "@parameter@"
   Current=   "@plot@"
   Plot=      "@tdrdat@"
}
Physics {
   Hydrodynamic( eTemperature )
   Mobility(
      eHighFieldSaturation
   )
   EffectiveIntrinsicDensity( NoBandGapNarrowing )
   Recombination(
      SRH Auger Radiative
   )
}
Physics( Material="GaAs" ){
   Mobility( Dopingdependence )
}
Physics( Material="AlGaAs" ){
   MoleFraction( xFraction= 0.30 Grading= 0)
}
Physics( Material="InGaAs"){
   MoleFraction( xFraction= 0.75 Grading= 0)
}

*----------------------------------------------------------------------*
* Upper buffer trap (R.GaAsUpper - unchanged from original code)
* @Si_UpperTrap_Conc@ is sweepable. Baseline: 1e16 cm^-3.
*----------------------------------------------------------------------*
Physics( Region="R.GaAsUpper" ){
    Traps(
       (Donor
        Conc=      @Si_UpperTrap_Conc@
        EnergyMid= 0.61  fromCondBand
        eXsection= 2.5e-18
        hXsection= 2.5e-16)
    )
}

*----------------------------------------------------------------------*
* Si-doped lower substrate traps (R.GaAsLower)
*
* Trap 1 - DX-centre / Si_Ga deep donor state  (EC - 0.15 eV)
*   Modelled as Acceptor because the DX state captures electrons from CB
*   and becomes negatively charged. This is the standard Sentaurus
*   convention for electron traps near the conduction band.
*   EnergyMid = 0.15 eV fromCondBand
*   Conc      = @Si_Trap1_Conc@
*
* Trap 2 - Si_As antisite compensating acceptor  (EV + 0.45 eV)
*   EnergyMid = 1.42 - 0.45 = 0.97 eV fromCondBand
*   Conc      = @Si_Trap2_Conc@
*----------------------------------------------------------------------*
Physics( Region="R.GaAsLower" ){
    Traps(

       * Trap 1 : DX-centre / Si_Ga deep electron trap  (EC - 0.15 eV)
       *          Large eXsection reflects strong lattice-relaxation coupling.
       (Acceptor
        Conc=      @Si_Trap1_Conc@
        EnergyMid= 0.15  fromCondBand
        eXsection= 1.0e-14
        hXsection= 1.0e-19)

       * Trap 2 : Si_As antisite compensating acceptor  (EV + 0.45 eV)
       (Acceptor
        Conc=      @Si_Trap2_Conc@
        EnergyMid= 0.97  fromCondBand
        eXsection= 2.0e-16
        hXsection= 1.0e-15)

    )
}

*----------------------------------------------------------------------*
} *- End of Device{}
*----------------------------------------------------------------------*
File{
   Output=    "@log@"
   ACExtract= "@acplot@"
}
System {
   HEMT hemt (gate=1 drain=2 source=0 substrate=0)
   Vsource_pset vg ( 1 0 ) { dc= 0 }
   Vsource_pset vd ( 2 0 ) { dc= 0 }
#if @Rfb@ != 0
   Resistor_pset Rfb (1 2) { resistance= @Rfb@ }
#endif
}
Plot{
*-- Density and Currents
   eDensity hDensity
   TotalCurrent/Vector eCurrent/Vector hCurrent/Vector
   eMobility hMobility
   eVelocity hVelocity
   eQuasiFermi hQuasiFermi
*-- Temperature
   eTemperature
*-- Fields and charges
   ElectricField/Vector Potential SpaceCharge
*-- Doping Profiles
   Doping DonorConcentration AcceptorConcentration
*-- Generation/Recombination
   SRH Auger
   AvalancheGeneration eAvalancheGeneration hAvalancheGeneration
*-- Driving forces
   eGradQuasiFermi/Vector hGradQuasiFermi/Vector
   eEparallel hEparalllel
*-- Band structure / Composition
   BandGap
   Affinity
   ConductionBand ValenceBand
   xMoleFraction
*-- Traps (Si-doped substrate)
   eTrappedCharge  hTrappedCharge
   eGapStatesRecombination hGapStatesRecombination
}
Math{
   Extrapolate
   Digits=           5
   Notdamped=        50
   Iterations=       15
   RelErrControl
   ErrRef(Electron)= 1e7
   ErrRef(Hole)=     1e4
   RelTermMinDensity=     1e4
   RelTermMinDensityZero= 1e7
   Number_of_Threads= 4
   Method=    Blocked SubMethod=   Pardiso
   ACMethod=  Blocked ACSubMethod= Pardiso
}
Solve{
*- Initial Solution
   NewCurrentPrefix="Init_"
   Coupled(Iterations= 100){ Poisson }
   Coupled{ Poisson Electron Hole }
   Coupled{ Poisson Electron Hole eTemperature }
*- Ramp drain to Vd, gate to VgMin
   Quasistationary(
      InitialStep= 0.01 Increment= 1.4
      MinStep= 1e-6 MaxStep= 0.25
      Goal{ Parameter= vg.dc Voltage= @Vgmin@ }
      Goal{ Parameter= vd.dc Voltage= @Vd@ }
  ){ Coupled { Poisson Electron Hole eTemperature } }
*- AC analysis: Ramp Gate to Vgmax
   NewCurrentPrefix=""
   Quasistationary(
      InitialStep= 0.1 Increment= 1.25
      MinStep= 1e-6 MaxStep= 0.05
      DoZero
      Goal{ Parameter= vg.dc Voltage=@Vgmax@ }
   ){ ACCoupled(
        StartFrequency= 1e8 EndFrequency= 1e12
        NumberOfPoints= @<nPerDecade*4+1>@ Decade
        Node(1 2) Exclude(vg vd)
        ACCompute( Time=(Range=(0 1) Intervals= 20) )
      ){ Poisson Electron Hole eTemperature }
      CurrentPlot( Time=(Range=(0 1) Intervals= 20) )
   }
}
(sde:build-mesh "n@node@_half_msh")
(system:command "tdx -mtt -y -ren drain=source n@node@_half_msh n@node@_msh")
(system:command "rm -f n@node@_half_msh.tdr")
